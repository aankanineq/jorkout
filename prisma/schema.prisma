generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// 공통
// ============================================

model Activity {
  id   String       @id @default(cuid())
  date DateTime     @db.Date
  type ActivityType
  notes String?

  liftSession LiftSession?
  runSession  RunSession?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ActivityType {
  LIFT
  RUN
}

// ============================================
// 헬스 - 모듈 시스템
// ============================================

enum ModuleCode {
  SQ // 스쿼트
  HN // 힙힌지
  PU // 수평푸시
  VU // 수직푸시
  PL // 수직풀
  RL // 수평풀
}

model Exercise {
  id         String     @id @default(cuid())
  name       String
  moduleCode ModuleCode
  isMain     Boolean    @default(false)
  notes      String?

  exerciseLogs ExerciseLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, moduleCode])
}

model LiftCycle {
  id         String      @id @default(cuid())
  number     Int
  splitCount Int
  status     CycleStatus @default(ACTIVE)
  startDate  DateTime    @db.Date
  endDate    DateTime?   @db.Date

  splits   SplitDay[]
  sessions LiftSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum CycleStatus {
  ACTIVE
  COMPLETED
}

model SplitDay {
  id       String @id @default(cuid())
  cycleId  String
  dayLabel String
  order    Int

  cycle    LiftCycle     @relation(fields: [cycleId], references: [id], onDelete: Cascade)
  modules  SplitModule[]
  sessions LiftSession[]

  createdAt DateTime @default(now())

  @@unique([cycleId, dayLabel])
}

model SplitModule {
  id         String     @id @default(cuid())
  splitDayId String
  moduleCode ModuleCode
  order      Int

  splitDay SplitDay @relation(fields: [splitDayId], references: [id], onDelete: Cascade)

  @@unique([splitDayId, moduleCode])
}

model LiftSession {
  id         String   @id @default(cuid())
  activityId String   @unique
  cycleId    String
  splitDayId String
  date       DateTime @db.Date
  duration   Int?
  notes      String?

  activity     Activity      @relation(fields: [activityId], references: [id], onDelete: Cascade)
  cycle        LiftCycle     @relation(fields: [cycleId], references: [id])
  splitDay     SplitDay      @relation(fields: [splitDayId], references: [id])
  exerciseLogs ExerciseLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExerciseLog {
  id         String     @id @default(cuid())
  sessionId  String
  exerciseId String
  moduleCode ModuleCode
  order      Int
  notes      String?

  session  LiftSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise Exercise    @relation(fields: [exerciseId], references: [id])
  sets     ExerciseSet[]

  createdAt DateTime @default(now())

  @@unique([sessionId, exerciseId])
}

model ExerciseSet {
  id            String  @id @default(cuid())
  exerciseLogId String
  setNumber     Int
  weight        Float
  reps          Int
  rpe           Float?
  isWarmup      Boolean @default(false)
  notes         String?

  exerciseLog ExerciseLog @relation(fields: [exerciseLogId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// ============================================
// 러닝
// ============================================

model Race {
  id         String     @id @default(cuid())
  name       String
  date       DateTime   @db.Date
  distance   Float
  goalTime   Int?
  actualTime Int?
  status     RaceStatus @default(UPCOMING)

  runPlan RunPlan?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum RaceStatus {
  UPCOMING
  COMPLETED
  DNS
  DNF
}

model RunPlan {
  id     String @id @default(cuid())
  raceId String @unique
  name   String

  race  Race      @relation(fields: [raceId], references: [id], onDelete: Cascade)
  weeks RunWeek[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RunWeek {
  id         String   @id @default(cuid())
  planId     String
  weekNumber Int
  startDate  DateTime @db.Date
  targetKm   Float
  phase      RunPhase
  notes      String?

  plan RunPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([planId, weekNumber])
}

enum RunPhase {
  BASE
  BUILD
  PEAK
  TAPER
  RACE_WEEK
  RECOVERY
}

model RunSession {
  id         String   @id @default(cuid())
  activityId String   @unique
  date       DateTime @db.Date
  distanceKm Float
  durationSec Int
  avgPace    Int
  rpe        Float?
  runType    RunType
  notes      String?
  raceId     String?

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum RunType {
  EASY
  TEMPO
  INTERVAL
  LONG
  RECOVERY
  RACE
  FARTLEK
}

// ============================================
// 바디 트래킹
// ============================================

model BodyLog {
  id      String   @id @default(cuid())
  date    DateTime @db.Date @unique
  weight  Float?
  bodyFat Float?
  notes   String?

  createdAt DateTime @default(now())
}
