generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// 공통
// ============================================

model Activity {
  id   String       @id @default(cuid())
  date DateTime     @db.Date
  type ActivityType
  notes String?

  liftSession LiftSession?
  runSession  RunSession?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum ActivityType {
  LIFT
  RUN
}

// ============================================
// 헬스 - PPL 3분할
// ============================================

enum SplitType {
  PUSH
  PULL
  LEG
}

enum ExerciseRole {
  MAIN
  VOLUME
}

model Exercise {
  id            String       @id @default(cuid())
  name          String       @unique
  splitType     SplitType
  role          ExerciseRole
  targetSets    Int
  targetMinReps Int
  targetMaxReps Int
  order         Int
  notes         String?

  exerciseLogs ExerciseLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LiftSession {
  id         String    @id @default(cuid())
  activityId String    @unique
  splitType  SplitType
  date       DateTime  @db.Date
  duration   Int?
  notes      String?

  activity     Activity      @relation(fields: [activityId], references: [id], onDelete: Cascade)
  exerciseLogs ExerciseLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExerciseLog {
  id         String @id @default(cuid())
  sessionId  String
  exerciseId String
  order      Int
  notes      String?

  session  LiftSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise Exercise    @relation(fields: [exerciseId], references: [id])
  sets     ExerciseSet[]

  createdAt DateTime @default(now())

  @@unique([sessionId, exerciseId])
}

model ExerciseSet {
  id            String  @id @default(cuid())
  exerciseLogId String
  setNumber     Int
  weight        Float
  reps          Int
  isWarmup      Boolean @default(false)
  notes         String?

  exerciseLog ExerciseLog @relation(fields: [exerciseLogId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// ============================================
// 러닝
// ============================================

model Race {
  id         String     @id @default(cuid())
  name       String
  date       DateTime   @db.Date
  distance   Float
  goalTime   Int?
  actualTime Int?
  status     RaceStatus @default(UPCOMING)

  runPlan RunPlan?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum RaceStatus {
  UPCOMING
  COMPLETED
  DNS
  DNF
}

model RunPlan {
  id     String @id @default(cuid())
  raceId String @unique
  name   String

  race  Race      @relation(fields: [raceId], references: [id], onDelete: Cascade)
  weeks RunWeek[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RunWeek {
  id         String   @id @default(cuid())
  planId     String
  weekNumber Int
  startDate  DateTime @db.Date
  targetKm   Float
  phase      RunPhase
  notes      String?

  plan RunPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([planId, weekNumber])
}

enum RunPhase {
  BASE
  BUILD
  PEAK
  TAPER
  RACE_WEEK
  RECOVERY
}

model RunSession {
  id         String   @id @default(cuid())
  activityId String   @unique
  date       DateTime @db.Date
  distanceKm Float
  durationSec Int
  avgPace    Int
  rpe        Float?
  runType    RunType
  notes      String?
  raceId     String?

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum RunType {
  EASY
  TEMPO
  INTERVAL
  LONG
  RECOVERY
  RACE
  FARTLEK
}

// ============================================
// 바디 트래킹
// ============================================

model BodyLog {
  id      String   @id @default(cuid())
  date    DateTime @db.Date @unique
  weight  Float?
  bodyFat Float?
  notes   String?

  createdAt DateTime @default(now())
}
