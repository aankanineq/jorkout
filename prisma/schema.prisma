generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Run {
  id        String   @id @default(uuid())
  date      DateTime @db.Date
  km        Float
  minutes   Int
  pace      Float?   // minutes / km
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([date])
  @@map("runs")
}

model Gym {
  id        String   @id @default(uuid())
  date      DateTime @db.Date
  exercise  String
  sets      Int
  reps      Int
  weight    Float
  volume    Float?   // sets × reps × weight
  rpe       Float?
  memo      String?
  raw       String   // "3x5x80"
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([date])
  @@index([exercise])
  @@map("gyms")
}
